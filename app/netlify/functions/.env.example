# Example environment variables for local testing
# Copy this file to .env and set real values before running locally

# Your Gemini API key (required for /api/chat and /api/chat/agent)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini API base URL and model
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash

# Port used by the local wrapper
PORT=8888

# Workspace directory (optional override). Defaults to /tmp/workspace
# WORKSPACE_DIR=/tmp/workspace
